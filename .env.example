# cronbase configuration
# Copy this file to .env and adjust as needed.
# All variables are optional — defaults work out of the box.

# Database path (default: ./cronbase.db)
# CRONBASE_DB=./cronbase.db

# API authentication token — protects the dashboard and API.
# Generate one with: openssl rand -hex 32
# CRONBASE_API_TOKEN=

# Default timezone for job schedules (IANA format, default: UTC)
# CRONBASE_TIMEZONE=America/New_York

# Log level: debug | info | warn | error (default: info)
# CRONBASE_LOG_LEVEL=info

# Log format: text | json (default: text)
# CRONBASE_LOG_FORMAT=text

# SMTP email alerting (optional — set CRONBASE_SMTP_HOST to enable)
# CRONBASE_SMTP_HOST=smtp.example.com
# CRONBASE_SMTP_PORT=587
# CRONBASE_SMTP_SECURE=false
# CRONBASE_SMTP_FROM=cronbase@localhost
# CRONBASE_SMTP_USERNAME=
# CRONBASE_SMTP_PASSWORD=
